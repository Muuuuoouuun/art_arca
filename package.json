    "generate-images:icons": "node --env-file=.env.local scripts/generate-images.mjs --type=icons",
    "generate-images:backgrounds": "node --env-file=.env.local scripts/generate-images.mjs --type=backgrounds"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
